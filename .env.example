# Local development — PostgreSQL
# On macOS: brew install postgresql && brew services start postgresql
# Then: createdb legitimate_properties
# Then update the URL with your local username:
# DATABASE_URL="postgresql://your_username@localhost:5432/legitimate_properties"

# Netlify/production — PostgreSQL (e.g. Neon, Supabase)
# Sign up for a free PostgreSQL provider, get your connection string:
# DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WA_NUMBER=
