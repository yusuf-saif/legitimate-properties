# Local development — PostgreSQL (required)
# On macOS: brew install postgresql && brew services start postgresql
# Then: createdb legitimate_properties
# Then update the URL with your local username:
# DATABASE_URL="postgresql://your_username@localhost:5432/legitimate_properties"

# Production — Render automatically injects DATABASE_URL via render.yaml
# No need to set it manually.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WA_NUMBER=
